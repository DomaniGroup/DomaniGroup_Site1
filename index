<style>
  :root{
    --maroon:#6B1836;
    --maroon-deep:#4A0E24;
    --maroon-bright:#88254A;
    --maroon-tint:#F7EFF2;
    --navy:#1E3D66;
    --navy-deep:#12294A;
    --bg:#FFFFFF;
    --wash:#F6F7F9;
    --ink:#171922;
    --muted:#5B6272;
    --line:rgba(23,25,34,.08);
    --line-strong:rgba(23,25,34,.16);
    --display:'Archivo',system-ui,sans-serif;
    --body:'Public Sans',system-ui,sans-serif;
    --mono:'IBM Plex Mono',ui-monospace,'SFMono-Regular',monospace;
    --radius:4px;
    --container:1120px;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--ink);font-family:var(--body);font-size:16.5px;line-height:1.65;-webkit-font-smoothing:antialiased}
  ::selection{background:rgba(107,24,54,.14)}
  a{color:inherit;text-decoration:none}
  img{max-width:100%;display:block}
  .container{max-width:var(--container);margin:0 auto;padding:0 24px}
  .skip{position:absolute;left:-9999px;top:0;z-index:200;background:var(--maroon);color:#fff;padding:10px 18px;font-family:var(--mono);font-size:13px}
  .skip:focus{left:16px;top:16px}
  :focus-visible{outline:2px solid var(--maroon);outline-offset:3px;border-radius:2px}

  /* ============ Chrome ============ */
  .cred{background:var(--maroon-deep);color:rgba(255,255,255,.66);font-family:var(--mono);font-size:11px;letter-spacing:.1em}
  .cred .container{display:flex;justify-content:space-between;align-items:center;height:36px}
  .cred b{color:#fff;font-weight:500}

  .nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.94);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);border-bottom:1px solid var(--line);transition:box-shadow .3s}
  .nav.scrolled{box-shadow:0 10px 30px -20px rgba(23,25,34,.35)}
  .nav .container{display:flex;align-items:center;justify-content:space-between;height:74px;gap:24px}
  .wordmark{display:flex;align-items:center;gap:12px}
  .wordmark img{height:36px;width:auto}
  .wordmark b{font-family:var(--display);font-weight:700;font-size:16px;letter-spacing:.13em;color:var(--maroon);white-space:nowrap}
  .nav-links{display:flex;gap:32px;align-items:center}
  .nav-links a{font-size:14.5px;font-weight:600;color:var(--muted);transition:color .2s}
  .nav-links a:hover{color:var(--maroon)}

  .btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;font-weight:600;font-size:15px;padding:13px 26px;border-radius:var(--radius);border:1px solid transparent;cursor:pointer;transition:background .2s,border-color .2s,color .2s,transform .2s;white-space:nowrap}
  .btn-solid{background:var(--maroon);color:#fff}
  .btn-solid:hover{background:var(--maroon-bright);transform:translateY(-1px)}
  .btn-ghost{border-color:var(--line-strong);color:var(--ink)}
  .btn-ghost:hover{border-color:var(--maroon);color:var(--maroon)}
  .btn-light{background:#fff;color:var(--maroon)}
  .btn-light:hover{background:var(--maroon-tint);transform:translateY(-1px)}
  .btn-sm{padding:10px 20px;font-size:14px}

  .burger{display:none;background:none;border:1px solid var(--line-strong);border-radius:var(--radius);width:42px;height:42px;cursor:pointer;flex-direction:column;align-items:center;justify-content:center;gap:5px}
  .burger span{display:block;width:18px;height:2px;background:var(--ink);transition:transform .25s,opacity .25s}
  .menu-open .burger span:nth-child(1){transform:translateY(7px) rotate(45deg)}
  .menu-open .burger span:nth-child(2){opacity:0}
  .menu-open .burger span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
  .mobile-menu{display:none;position:fixed;inset:0;z-index:99;background:var(--bg);padding:120px 24px 40px;flex-direction:column;gap:8px}
  .menu-open .mobile-menu{display:flex}
  .mobile-menu a{font-family:var(--display);font-size:26px;font-weight:700;padding:14px 0;border-bottom:1px solid var(--line)}
  .mobile-menu .btn{margin-top:28px}
  .menu-open{overflow:hidden}

  /* ============ Type patterns ============ */
  .eyebrow{display:inline-flex;align-items:center;gap:12px;font-family:var(--mono);font-size:11px;font-weight:500;letter-spacing:.22em;text-transform:uppercase;color:var(--maroon)}
  .eyebrow::before{content:"";width:26px;height:1px;background:var(--maroon)}
  .section{padding:100px 0}
  .section-head{max-width:640px;margin-bottom:56px}
  h2.title{font-family:var(--display);font-weight:700;font-size:clamp(1.85rem,3.2vw,2.4rem);line-height:1.15;letter-spacing:-.02em;margin-top:18px}
  .section-head p{color:var(--muted);margin-top:14px}

  /* ============ Hero ============ */
  .hero{position:relative;overflow:hidden}
  .hero::before{content:"";position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:56px 56px;opacity:.5;-webkit-mask-image:radial-gradient(110% 90% at 72% 4%,#000 20%,transparent 70%);mask-image:radial-gradient(110% 90% at 72% 4%,#000 20%,transparent 70%)}
  .hero .container{position:relative;z-index:1;display:grid;grid-template-columns:1.05fr .95fr;gap:64px;align-items:center;padding-top:84px;padding-bottom:96px}
  .flag{display:inline-flex;align-items:center;gap:11px;background:var(--bg);border:1px solid var(--line-strong);border-radius:100px;padding:7px 15px 7px 8px;font-family:var(--mono);font-size:11.5px;letter-spacing:.06em;color:var(--muted);margin-bottom:28px;transition:border-color .2s,color .2s}
  .flag .pill{background:var(--maroon);color:#fff;border-radius:100px;padding:3px 10px;font-size:9.5px;letter-spacing:.16em}
  .flag b{color:var(--ink);font-weight:500}
  .flag .arrow{transition:transform .2s}
  .flag:hover{border-color:var(--maroon);color:var(--maroon)}
  .flag:hover .arrow{transform:translateX(3px)}
  .hero h1{font-family:var(--display);font-weight:700;font-size:clamp(2.6rem,5.4vw,4.15rem);line-height:1.04;letter-spacing:-.03em;margin:0 0 22px}
  .hero h1 .dot{color:var(--maroon)}
  .hero .lede{color:var(--muted);font-size:18px;max-width:500px}
  .hero .lede strong{color:var(--ink);font-weight:600}
  .hero-ctas{display:flex;gap:14px;margin-top:34px;flex-wrap:wrap}

  /* ============ Panel ============ */
  .panel{background:var(--bg);border:1px solid var(--line-strong);border-top:3px solid var(--maroon);border-radius:var(--radius);box-shadow:0 30px 60px -34px rgba(23,25,34,.35)}
  .panel-head{display:flex;justify-content:space-between;align-items:center;gap:16px;padding:13px 18px;border-bottom:1px solid var(--line);font-family:var(--mono);font-size:10.5px;letter-spacing:.14em;color:var(--muted)}
  .panel-head .live{display:flex;align-items:center;gap:9px;color:var(--maroon)}
  .live-dot{width:7px;height:7px;border-radius:50%;background:var(--maroon);box-shadow:0 0 0 0 rgba(107,24,54,.5);animation:pulse 2.2s infinite}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(107,24,54,.4)}70%{box-shadow:0 0 0 9px rgba(107,24,54,0)}100%{box-shadow:0 0 0 0 rgba(107,24,54,0)}}
  .panel-chart{padding:20px 14px 12px}
  .panel-chart svg{width:100%;height:auto;display:block}
  .chart-grid line{stroke:var(--line);stroke-width:1}
  .chart-axis text{font-family:var(--mono);font-size:9px;fill:var(--muted);letter-spacing:.08em}
  .chart-plan{fill:none;stroke:var(--navy);stroke-width:1.5;stroke-dasharray:5 6;opacity:.8}
  .chart-plan-label{font-family:var(--mono);font-size:8.5px;fill:var(--navy);letter-spacing:.14em}
  .chart-exec{fill:none;stroke:var(--maroon);stroke-width:2.4;stroke-linecap:round;stroke-linejoin:round}
  .chart-fill{fill:url(#execgrad)}
  .chart-today{stroke:rgba(107,24,54,.35);stroke-width:1;stroke-dasharray:2 4}
  .chart-today-label{font-family:var(--mono);font-size:8.5px;fill:var(--maroon);letter-spacing:.12em}
  .chart-endpoint{fill:var(--maroon)}
  .chart-endlabel{font-family:var(--mono);font-size:10px;fill:var(--maroon);font-weight:500}
  .panel-stats{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--line)}
  .panel-stats div{padding:13px 18px;border-right:1px solid var(--line);font-family:var(--mono)}
  .panel-stats div:last-child{border-right:none}
  .panel-stats small{display:block;font-size:9.5px;letter-spacing:.14em;color:var(--muted);margin-bottom:4px}
  .panel-stats strong{font-size:14.5px;font-weight:500;color:var(--ink)}

  /* ============ Proof ============ */
  .proof{border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:30px 0}
  .proof .container{display:flex;flex-wrap:wrap;align-items:baseline;gap:14px 40px}
  .proof-label{font-family:var(--mono);font-size:10.5px;letter-spacing:.2em;color:var(--muted);text-transform:uppercase;flex:none}
  .proof-names{display:flex;flex-wrap:wrap;gap:10px 28px;font-family:var(--mono);font-size:12px;letter-spacing:.1em;color:var(--ink);text-transform:uppercase}
  .proof-names span{opacity:.8}
  .proof-names .first{color:var(--maroon);opacity:1;font-weight:500}

  /* ============ Capabilities ============ */
  .cap-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
  .card{position:relative;overflow:hidden;display:flex;flex-direction:column;background:var(--bg);border:1px solid var(--line);border-radius:var(--radius);padding:30px;transition:border-color .25s,transform .25s,box-shadow .25s}
  .card::before{content:"";position:absolute;top:0;left:0;height:2px;width:100%;background:var(--maroon);transform:scaleX(0);transform-origin:left;transition:transform .4s cubic-bezier(.5,0,.2,1)}
  .card:hover{border-color:var(--line-strong);transform:translateY(-3px);box-shadow:0 24px 50px -34px rgba(23,25,34,.3)}
  .card:hover::before{transform:scaleX(1)}
  .chip{width:44px;height:44px;border-radius:var(--radius);background:var(--maroon-tint);color:var(--maroon);display:grid;place-items:center;margin-bottom:20px}
  .card h3{font-family:var(--display);font-weight:600;font-size:20px;letter-spacing:-.015em;margin-bottom:10px}
  .card p{color:var(--muted);font-size:15.5px}
  .card-tags{margin-top:auto;padding-top:20px;font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--muted)}
  .card-tags::before{content:"";display:block;width:100%;height:1px;background:var(--line);margin-bottom:14px}

  /* ============ Approach ============ */
  .approach{background:var(--wash);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .approach-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}
  .checklist{list-style:none;margin-top:34px}
  .checklist li{display:flex;gap:15px;padding:15px 0;border-bottom:1px solid var(--line-strong);font-size:15.5px}
  .checklist li:first-child{border-top:1px solid var(--line-strong)}
  .checklist .ck{flex:none;width:18px;height:18px;margin-top:3px;color:var(--maroon)}
  .lane-label{margin-bottom:34px}
  .timeline{position:relative;padding-left:34px}
  .timeline::before{content:"";position:absolute;left:6px;top:8px;bottom:8px;width:1px;background:var(--line-strong)}
  .step{position:relative;padding:0 0 40px}
  .step:last-child{padding-bottom:0}
  .step::before{content:"";position:absolute;left:-32px;top:6px;width:13px;height:13px;border-radius:50%;background:var(--wash);border:2px solid var(--maroon)}
  .step-meta{display:flex;gap:16px;align-items:baseline;font-family:var(--mono);font-size:11px;letter-spacing:.18em}
  .step-meta .num{color:var(--maroon)}
  .step-meta .wk{color:var(--muted)}
  .step h4{font-family:var(--display);font-weight:600;font-size:18px;margin:8px 0 7px;letter-spacing:-.01em}
  .step p{color:var(--muted);font-size:15.5px;max-width:430px}

  /* ============ Flagship ============ */
  .flagship{position:relative;overflow:hidden;border-radius:var(--radius);color:#fff;background:linear-gradient(130deg,var(--navy-deep),var(--navy) 80%);padding:46px 48px;margin-bottom:20px}
  .flagship::after{content:"";position:absolute;top:-140px;right:-120px;width:440px;height:440px;background:radial-gradient(circle,rgba(136,37,74,.38),transparent 62%);pointer-events:none}
  .flagship-inner{position:relative;z-index:1;display:grid;grid-template-columns:1.35fr 1fr;gap:56px;align-items:center}
  .fs-eyebrow{display:inline-flex;align-items:center;gap:10px;font-family:var(--mono);font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:#DFB4C4}
  .fs-eyebrow .pill{background:var(--maroon);color:#fff;border-radius:100px;padding:3px 10px;font-size:9.5px;letter-spacing:.16em}
  .flagship h3{font-family:var(--display);font-weight:700;font-size:clamp(1.5rem,2.6vw,1.95rem);line-height:1.12;letter-spacing:-.02em;margin-top:16px}
  .flagship h3 em{font-style:normal;color:#DFB4C4}
  .flagship .fs-body{color:rgba(255,255,255,.82);font-size:15.5px;margin-top:14px;max-width:540px}
  .fs-spec{border-top:1px solid rgba(255,255,255,.16)}
  .fs-spec div{display:grid;grid-template-columns:96px 1fr;gap:18px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.16);align-items:baseline}
  .fs-spec dt{font-family:var(--mono);font-size:10px;letter-spacing:.18em;color:rgba(255,255,255,.55)}
  .fs-spec dd{font-size:14.5px;font-weight:600}

  /* ============ Past performance ============ */
  .perf-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
  .perf{background:var(--bg);border:1px solid var(--line);border-left:2px solid var(--maroon);border-radius:var(--radius);padding:28px 30px;transition:border-color .25s,transform .25s,box-shadow .25s}
  .perf:hover{border-left-color:var(--maroon-bright);transform:translateY(-3px);box-shadow:0 24px 50px -36px rgba(23,25,34,.3)}
  .perf-tag{font-family:var(--mono);font-size:10px;letter-spacing:.16em;color:var(--maroon);text-transform:uppercase}
  .perf h3{font-family:var(--display);font-weight:600;font-size:19px;margin:11px 0 9px;letter-spacing:-.015em}
  .perf p{color:var(--muted);font-size:15.5px}
  .readiness{margin-top:52px;border:1px solid var(--line);border-radius:var(--radius);background:linear-gradient(90deg,var(--maroon-tint),var(--bg) 55%);display:grid;grid-template-columns:1fr 1fr;gap:32px;padding:36px 40px;align-items:center}
  .readiness h3{font-family:var(--display);font-weight:700;font-size:clamp(1.25rem,2.1vw,1.55rem);letter-spacing:-.02em;line-height:1.3}
  .readiness h3 b{color:var(--maroon)}
  .readiness .r-note{color:var(--muted);font-size:15.5px}
  .readiness .eyebrow{margin-bottom:12px}

  /* ============ Leadership ============ */
  .lead{border-top:1px solid var(--line)}
  .lead-grid{display:grid;grid-template-columns:360px 1fr;gap:64px;align-items:start}
  .lead-photo{position:relative;border:1px solid var(--line-strong);border-radius:var(--radius);overflow:hidden;aspect-ratio:4/5;background:var(--wash)}
  .lead-photo img{width:100%;height:100%;object-fit:cover}
  .lead-photo .fallback{display:none;position:absolute;inset:0;align-items:center;justify-content:center;font-family:var(--display);font-size:60px;font-weight:700;color:var(--maroon);letter-spacing:.06em}
  .lead-photo.noimg .fallback{display:flex}
  .lead-name{font-family:var(--display);font-weight:700;font-size:24px;letter-spacing:-.02em;margin-top:20px}
  .lead-title{font-family:var(--mono);font-size:11px;letter-spacing:.16em;color:var(--maroon);text-transform:uppercase;margin-top:6px}
  .lead-bio .eyebrow{margin-bottom:24px}
  .lead-bio p{color:var(--muted);margin-bottom:17px;font-size:16px}
  .lead-bio p strong{color:var(--ink);font-weight:600}

  /* ============ Contact ============ */
  .contact{position:relative;overflow:hidden;text-align:center;padding:120px 0;background:linear-gradient(135deg,var(--maroon-deep),var(--maroon) 92%);color:#fff}
  .contact::before{content:"";position:absolute;top:50%;right:-140px;width:480px;height:480px;transform:translateY(-50%);background:url('logo-mark-white.png') center/contain no-repeat;opacity:.06;pointer-events:none}
  .contact .container{position:relative;z-index:1}
  .contact .eyebrow{justify-content:center;color:#DFB4C4}
  .contact .eyebrow::before{background:#DFB4C4}
  .contact .eyebrow::after{content:"";width:26px;height:1px;background:#DFB4C4}
  .contact h2{font-family:var(--display);font-weight:700;font-size:clamp(2rem,4.2vw,3.1rem);letter-spacing:-.025em;line-height:1.1;margin:20px auto 18px;max-width:740px}
  .contact .sub{color:rgba(255,255,255,.82);max-width:580px;margin:0 auto;font-size:17px}
  .contact-ctas{margin-top:38px}
  .contact-mail{display:inline-block;margin-top:24px;font-family:var(--mono);font-size:13px;letter-spacing:.08em;color:rgba(255,255,255,.75);border-bottom:1px solid rgba(255,255,255,.35);padding-bottom:3px;transition:color .2s,border-color .2s}
  .contact-mail:hover{color:#fff;border-color:#fff}

  /* ============ Footer ============ */
  footer{padding:60px 0 36px}
  .foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:48px;padding-bottom:44px;border-bottom:1px solid var(--line)}
  .foot-brand img{width:150px;height:auto}
  .foot-brand p{color:var(--muted);font-size:14.5px;margin-top:20px;max-width:320px}
  .foot-col h5{font-family:var(--mono);font-size:10.5px;letter-spacing:.2em;color:var(--muted);text-transform:uppercase;margin-bottom:16px;font-weight:500}
  .foot-col a{display:block;font-size:15px;padding:5px 0;transition:color .2s}
  .foot-col a:hover{color:var(--maroon)}
  .foot-col .mono{font-family:var(--mono);font-size:12.5px;letter-spacing:.06em;color:var(--muted);margin-top:14px}
  .foot-bottom{display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;padding-top:26px;font-family:var(--mono);font-size:10.5px;letter-spacing:.12em;color:var(--muted)}

  /* ============ Motion ============ */
  html.js .reveal{opacity:0;transform:translateY(14px);transition:opacity .65s ease,transform .65s ease}
  html.js .reveal.in{opacity:1;transform:none}
  html.js .chart-exec{transition:stroke-dashoffset 1.6s cubic-bezier(.5,0,.2,1)}
  html.js .panel .chart-plan,html.js .panel .chart-fill,html.js .panel .chart-plan-label{opacity:0;transition:opacity .9s ease .3s}
  html.js .panel.drawn .chart-plan{opacity:.8}
  html.js .panel.drawn .chart-fill,html.js .panel.drawn .chart-plan-label{opacity:1}
  html.js .panel .chart-endpoint,html.js .panel .chart-endlabel{opacity:0;transition:opacity .5s ease 1.7s}
  html.js .panel.drawn .chart-endpoint,html.js .panel.drawn .chart-endlabel{opacity:1}

  @media (prefers-reduced-motion:reduce){
    html{scroll-behavior:auto}
    html.js .reveal{opacity:1;transform:none;transition:none}
    html.js .chart-exec{transition:none}
    html.js .panel .chart-plan{opacity:.8;transition:none}
    html.js .panel .chart-fill,html.js .panel .chart-plan-label,
    html.js .panel .chart-endpoint,html.js .panel .chart-endlabel{opacity:1;transition:none}
    .live-dot{animation:none}
    .btn,.card,.perf,.flag{transition:none}
  }

  /* ============ Responsive ============ */
  @media (max-width:1000px){
    .hero .container{grid-template-columns:1fr;gap:52px;padding-top:60px;padding-bottom:72px}
    .approach-grid{grid-template-columns:1fr;gap:56px}
    .flagship-inner{grid-template-columns:1fr;gap:32px}
    .lead-grid{grid-template-columns:1fr;gap:40px}
    .lead-photo{max-width:360px}
    .foot-grid{grid-template-columns:1fr 1fr}
  }
  @media (max-width:760px){
    .section{padding:72px 0}
    .nav-links,.btn-nav{display:none}
    .burger{display:flex}
